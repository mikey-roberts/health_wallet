<div class="lab-upload-card">
  <%= form_with model: LabUpload.new, local: true, html: { multipart: true, class: "lab-upload-form" } do |form| %>
    <div class="form-group">
      <%= form.label :file, "Select HL7 file" %>
      <%= form.file_field :file, required: true, accept: ".txt,.hl7,text/plain" %>
    </div>

    <div class="form-group">
      <%= form.submit "Upload and Process", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
